# demo: 使用确定性模拟结果；production: 调用真实 Ollama 和知识库
APP_MODE=production
APP_NAME=medical-multi-agent
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# 必填：生产环境请改成长随机值
APP_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# PostgreSQL / Redis / 对象存储
DATABASE_URL=postgresql+asyncpg://medical:CHANGE_ME@postgres:5432/medical_agents
POSTGRES_PASSWORD=CHANGE_ME
REDIS_URL=redis://redis:6379/0
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY=CHANGE_ME
OBJECT_STORAGE_SECRET_KEY=CHANGE_ME
OBJECT_STORAGE_BUCKET=medical-images

# Ollama（已按目标虚拟机配置）
OLLAMA_BASE_URL=http://172.16.98.104:11434
OLLAMA_VERIFY_SSL=true
OLLAMA_CA_CERT=
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_KEEP_ALIVE=0
IMAGE_ANALYST_MODEL=medgemma1.5:4b
RETRIEVER_EMBEDDING_MODEL=bge-m3:latest
RETRIEVER_RERANKER_MODEL=
LEAD_PHYSICIAN_MODEL=medgemma:27b
AUDITOR_MODEL=qwen3.6:27b-bf16

# IU X-Ray：直接运行使用相对项目路径；Docker内会覆盖为容器路径
IU_XRAY_DATASET_PATH=./data/iu-xray
KNOWLEDGE_DOCUMENT_PATH=./knowledge_base/approved_documents
KNOWLEDGE_TOP_K=5

# 可选专用医学影像模型服务；IU X-Ray 首版可留空
TRITON_URL=
XRAY_MODEL_NAME=
CHEST_CT_MODEL_NAME=

# 医院系统
DICOMWEB_BASE_URL=https://YOUR_PACS/dicom-web
DICOMWEB_USERNAME=CHANGE_ME
DICOMWEB_PASSWORD=CHANGE_ME
FHIR_BASE_URL=https://YOUR_FHIR_SERVER/fhir
FHIR_TOKEN=CHANGE_ME

# 可观测性：生产环境必须私有化，并在发送前脱敏
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=CHANGE_ME
LANGFUSE_SECRET_KEY=CHANGE_ME

# 医院/科室配置
HOSPITAL_NAME=YOUR_HOSPITAL_NAME
DEPARTMENT_NAME=YOUR_DEPARTMENT_NAME
KNOWLEDGE_APPROVER=YOUR_MEDICAL_KNOWLEDGE_APPROVER
