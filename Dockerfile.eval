FROM python:3.11-slim
WORKDIR /app
COPY pyproject.toml README.md ./
COPY app ./app
COPY evaluation ./evaluation
COPY scripts ./scripts
ARG PIP_INDEX_URL=https://pypi.org/simple
ARG TORCH_INDEX_URL=https://download.pytorch.org/whl/cu128
ENV PIP_DEFAULT_TIMEOUT=300
# Pin the verified CUDA 12.8 build first.  Otherwise pip currently resolves the
# newest PyTorch/CUDA 13 stack through RadEval, adding several multi-GB wheels.
RUN pip install --no-cache-dir --retries 10 \
    --index-url "${TORCH_INDEX_URL}" \
    torch==2.9.1 torchvision==0.24.1
RUN pip install --no-cache-dir --retries 10 ".[evaluation]"
ENV PYTHONPATH=/app
CMD ["python", "scripts/evaluate_reports.py", "--help"]
